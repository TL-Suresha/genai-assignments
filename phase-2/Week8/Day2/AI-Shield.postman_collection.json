{
  "info": {
    "name": "AI-Shield Moderation API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Phase-wise API tests for AI-Shield architecture implementation. Includes optional hardening (rate limiting + API key auth) beyond the original spec — set AUTH_ENABLED=true on the server and populate the `apiKey` collection variable to exercise auth."
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "x-api-key" },
      { "key": "value", "value": "{{apiKey}}" },
      { "key": "in", "value": "header" }
    ]
  },
  "item": [
    {
      "name": "Phase 1 - Project Setup and Scaffolding",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:4000/api/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Phase 5 - PII Detector",
      "item": [
        {
          "name": "Detect PII - Email and Aadhaar (MASK)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"My email is john.doe@gmail.com and my Aadhaar is 2345 6789 0123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/detect/pii",
              "host": ["{{baseUrl}}"],
              "path": ["api", "detect", "pii"]
            }
          },
          "response": []
        },
        {
          "name": "Detect PII - Clean Text (ALLOW)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Write me a test case for login functionality\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/detect/pii",
              "host": ["{{baseUrl}}"],
              "path": ["api", "detect", "pii"]
            }
          },
          "response": []
        },
        {
          "name": "Detect PII - Missing text (400 Error)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/detect/pii",
              "host": ["{{baseUrl}}"],
              "path": ["api", "detect", "pii"]
            }
          },
          "response": []
        }
      ]
    },
