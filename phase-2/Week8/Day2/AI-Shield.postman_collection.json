    {
      "name": "Phase 10 - File Validator",
      "item": [
        {
          "name": "Detect File - Invalid Extension .exe (BLOCK)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/detect/file",
              "host": ["{{baseUrl}}"],
              "path": ["api", "detect", "file"]
            },
            "description": "Attach a .exe file to this form-data 'file' field to validate BLOCK response."
          },
          "response": []
        },
        {
          "name": "Detect File - Valid .csv (ALLOW)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/detect/file",
              "host": ["{{baseUrl}}"],
              "path": ["api", "detect", "file"]
            },
            "description": "Attach a .csv file (under 5MB) to this form-data 'file' field to validate ALLOW response."
          },
          "response": []
        }
      ]
